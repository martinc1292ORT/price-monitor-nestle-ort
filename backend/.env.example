# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────────────────────────────────────────

# URL de conexión a PostgreSQL
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB
# En Docker: host = nombre del servicio (postgres)
# En local:  host = localhost
DATABASE_URL=postgresql://user:password@postgres:5432/price_monitor

# ─────────────────────────────────────────────────────────────────────────────
# REDIS (Message Broker para BullMQ)
# ─────────────────────────────────────────────────────────────────────────────

# Host de Redis — en Docker usar el nombre del servicio
REDIS_HOST=redis

# Puerto estándar de Redis
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────────
# JWT — Autenticación
# ─────────────────────────────────────────────────────────────────────────────

# Secreto para firmar los tokens JWT. Mínimo 64 caracteres aleatorios.
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar_por_un_secreto_largo_y_aleatorio_minimo_64_chars

# Tiempo de expiración del access token (short-lived)
JWT_ACCESS_EXPIRES=15m

# Tiempo de expiración del refresh token (long-lived)
JWT_REFRESH_EXPIRES=7d

# ─────────────────────────────────────────────────────────────────────────────
# APLICACIÓN
# ─────────────────────────────────────────────────────────────────────────────

# Entorno de ejecución: development | production | test
NODE_ENV=development

# Puerto en el que escucha el backend
PORT=3000

# Cantidad de scrapers en paralelo (ajustar según recursos del servidor)
SCRAPING_CONCURRENCY=2

# Ruta base donde se guardan screenshots y HTML de evidencia
EVIDENCE_BASE_PATH=./evidence

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL — Notificaciones de alertas (Nodemailer)
# ─────────────────────────────────────────────────────────────────────────────

# Servidor SMTP saliente
SMTP_HOST=

# Puerto SMTP (587 para STARTTLS, 465 para SSL)
SMTP_PORT=587

# Usuario SMTP (generalmente la dirección de email)
SMTP_USER=

# Contraseña o App Password del usuario SMTP
SMTP_PASS=

# Dirección que aparece como remitente en las alertas por email
ALERT_EMAIL_FROM=

# Destinatario(s) de las alertas. Separar múltiples con coma.
ALERT_EMAIL_TO=
